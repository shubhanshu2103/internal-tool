# ── Groq (LLM judge — free API, no local RAM) ────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local embeddings only — lightweight) ──────────────────────────────
# Run `ollama serve` before starting the backend.
# Pull with: ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG Parameters ────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=3
MIN_SIMILARITY=0.30

# ── Storage Paths (relative to backend/) ─────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
RUBRIC_PATH=./data/rubric/rubric.json
OUTPUTS_DIR=./data/outputs
