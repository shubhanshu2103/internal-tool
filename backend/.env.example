# ── Groq (LLM judge — free API) ───────────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── Jina AI (embeddings — free API, 1M tokens) ────────────────────────────────
# Get a free key at: https://jina.ai
JINA_API_KEY=jina_...
JINA_EMBED_MODEL=jina-embeddings-v2-base-en

# ── RAG Parameters ────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=3
MIN_SIMILARITY=0.30

# ── Storage Paths (relative to backend/) — override in production ─────────────
CHROMA_PERSIST_DIR=./data/chroma_db
RUBRIC_PATH=./data/rubric/rubric.json
OUTPUTS_DIR=./data/outputs
